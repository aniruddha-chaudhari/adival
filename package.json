{
  "name": "hono-server",
  "version": "1.0.0",
  "description": "A Hono server with TypeScript for function execution",
  "main": "src/index.ts",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^1.22.0",
    "@modelcontextprotocol/sdk": "^1.19.1",
    "agent-browser": "^0.15.0",
    "docx": "^9.5.1",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@8.0.0"
}
