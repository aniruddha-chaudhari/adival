      <w:r>
        <w:t>Service Agreement Contract</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>This Service Agreement ('Agreement') is entered into as of the date last signed below.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>WHEREAS, the Company desires to engage the Contractor to perform certain services;</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>WHEREAS, the Contractor desires to perform such services for the Company;</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>NOW, THEREFORE, in consideration of the mutual covenants and agreements set forth herein:</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>1. SERVICES. The Contractor agrees to perform the services described in Exhibit A.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>2. COMPENSATION. The Company shall pay the Contractor according to the rate schedule in Exhibit B.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>3. TERM. This Agreement shall commence on the Effective Date and continue for twelve (12) months.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>4. TERMINATION. Either party may terminate this Agreement with thirty (30) days written notice.</w:t>
      </w:r>
    </w:p>
    <w:p>
      <w:r>
        <w:t>5. CONFIDENTIALITY. The Contractor agrees to maintain confidentiality of all proprietary information.</w:t>
      </w:r>
    </w:p>
    <w:p/>
