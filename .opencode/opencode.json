{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": false
    },
    "fast-play": {
      "type": "local",
      "command": ["npx", "@tontoko/fast-playwright-mcp"],
      "enabled": false
    },
    "supermemory": {
      "type": "remote",
      "url": "https://mcp.supermemory.ai/mcp",
      "enabled": false
    }
  }
}
